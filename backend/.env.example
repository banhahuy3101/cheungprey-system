# SUPABASE_DB_PASSWORD=<your-db-password>
# Personal access token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=<your-access-token>

# Comma-separated frontend origins for CORS (optional; *.onrender.com also allowed)
# CORS_ORIGIN=https://cheung-prey-system.onrender.com,https://cheungprey-system.onrender.com,http://localhost:5173
