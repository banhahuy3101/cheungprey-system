# npm run dev — browser calls /api on same origin (no mixed-content).
VITE_API_URL=/api

# Proxy target (server-side only, HTTP is OK here):
# Local backend:
VITE_API_PROXY_TARGET=http://127.0.0.1:8080

# Test AWS backend from local dev (uncomment, set current ECS IP, restart Vite):
# VITE_API_PROXY_TARGET=http://13.212.156.15:8080
