# Vite env files (only VITE_* is exposed to the browser)
#
# .env.development  → npm run dev with local backend (proxy /api → :8080)
# .env.production   → npm run build for production
# .env              → optional overrides (gitignored)

# Local backend (default dev)
VITE_API_URL=/api

# Render backend
# VITE_API_URL=https://cheungprey-system.onrender.com/api
