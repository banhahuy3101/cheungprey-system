# Vite env files (only VITE_* is exposed to the browser)
#
# .env.development  → npm run dev with local backend (proxy /api → :8080)
# .env.production   → npm run build for production
# .env              → optional overrides (gitignored)

# Local backend (default dev)
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8080

# Test AWS from local dev (proxy avoids mixed-content; update IP after ECS redeploy):
# VITE_API_PROXY_TARGET=http://13.212.156.15:8080

# Production must use HTTPS API if frontend is HTTPS:
# Render HTTPS static site + HTTP AWS API: set VITE_API_URL=/api and add a Render
# Rewrite: /api/* → http://<aws-ip>:8080/api/* (above the /* → /index.html rule).
# VITE_API_URL=https://your-api.example.com/api
