# Production build (npm run build)
# Render static site (Dashboard → Redirects/Rewrites, rules in render.yaml):
#   1) VITE_API_URL=/api
#   2) Rewrite /api/* → http://<aws-ip>:8080/api/*  (above /* → /index.html)
# Or use Docker frontend (cheungprey-web) with API_UPSTREAM env — no rewrite needed.
VITE_API_URL=/api
